{
  "name": "aria-chatbot",
  "productName": "Aria ChatBot",
  "version": "0.2.5",
  "description": "High-End Interactive Fiction & Storytelling Suite",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "clean": "rimraf dist",
    "dev": "concurrently \"npm run dev:react\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "dev:react": "vite",
    "build:react": "npm run clean && vite build",
    "build": "npm run build:react && electron-builder",
    "pack": "npm run build:react && electron-builder --dir",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "Gakuseeii",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "framer-motion": "^12.27.5",
    "lucide-react": "^0.562.0",
    "react-hot-toast": "^2.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^39.8.6",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.38",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^6.1.2",
    "tailwindcss": "^3.4.3",
    "vite": "^7.3.2",
    "vitest": "^4.0.18",
    "wait-on": "^7.2.0"
  },
  "overrides": {
    "axios": "1.15.0",
    "lodash": "4.18.1",
    "anymatch": {
      "picomatch": "2.3.2"
    },
    "chokidar": {
      "picomatch": "2.3.2"
    },
    "fdir": {
      "picomatch": "4.0.4"
    },
    "micromatch": {
      "picomatch": "2.3.2"
    },
    "readdirp": {
      "picomatch": "2.3.2"
    },
    "tinyglobby": {
      "picomatch": "4.0.4"
    },
    "vite": {
      "picomatch": "4.0.4"
    },
    "vitest": {
      "picomatch": "4.0.4"
    }
  },
  "build": {
    "appId": "com.aria.chatbot",
    "productName": "Aria",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "dist/**/*",
      "lib/**/*",
      "tools/zonos_api_server.py"
    ],
    "electronFuses": {
      "runAsNode": false,
      "enableCookieEncryption": true,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "enableEmbeddedAsarIntegrityValidation": true,
      "onlyLoadAppFromAsar": true
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Aria"
    }
  }
}
