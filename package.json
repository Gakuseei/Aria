{
  "name": "aria-chatbot",
  "productName": "Aria ChatBot",
  "version": "0.2.5",
  "description": "High-End Interactive Fiction & Storytelling Suite",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "clean": "rimraf dist",
    "dev": "concurrently \"npm run dev:react\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "dev:react": "vite",
    "build:react": "npm run clean && vite build",
    "build": "npm run build:react && electron-builder",
    "pack": "npm run build:react && electron-builder --dir",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "Gakuseeii",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.3.1",
    "framer-motion": "^12.27.5",
    "lucide-react": "^0.577.0",
"react-hot-toast": "^2.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.8.2",
    "electron-builder": "^26.0.12",
    "postcss": "^8.4.38",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^6.1.2",
    "tailwindcss": "^3.4.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.aria.chatbot",
    "productName": "Aria",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "dist/**/*",
      "lib/**/*",
      "tools/zonos_api_server.py",
      "tools/debug_zonos.js",
      "tools/README.txt"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.icns",
      "category": "public.app-category.utilities"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Aria"
    }
  }
}
